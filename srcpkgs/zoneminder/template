# Template file for 'zoneminder'
pkgname=zoneminder
version=1.38.3
revision=1

system_groups="www-data" # Ensures the target group exists on the user's host OS

build_style=cmake

# Complete destination array mapping for ZoneMinder 1.36+
configure_args="
 -DCMAKE_INSTALL_PREFIX=/usr
 -DZM_WEBDIR=/usr/share/zoneminder/www
 -DZM_CGIDIR=/usr/libexec/zoneminder/cgi-bin
 -DZM_RUNDIR=/run/zoneminder
 -DZM_SOCKDIR=/run/zoneminder
 -DZM_LOGDIR=/var/log/zoneminder
 -DZM_CONFIG_DIR=/etc/zm
 -DZM_CONFIG_SUBDIR=/etc/zm/conf.d
 -DZM_PERL_SUBPREFIX=/usr/lib/perl5/vendor_perl
 -DZM_SYSCONFDIR=/etc/zm
 -DZM_POLKIT_DIR=/usr/share/polkit-1/actions
 -DZM_SYSTEMD_UNITDIR=/usr/lib/systemd/system
 -DZM_MANDIR=/usr/share/man
 -DZM_INCLUDEDIR=/usr/include
 -DZM_CACHEDIR=/var/cache/zoneminder/cache
 -DZM_WEB_USER=www-data
 -DZM_WEB_GROUP=www-data
"

# Add git so xbps-src can download the submodules

hostmakedepends="git pkg-config cmake perl"
makedepends="ffmpeg-devel iproute2 net-tools libmariadbclient-devel libcurl-devel libjpeg-turbo-devel
 pcre-devel libgcrypt-devel gnutls-devel vlc-devel libvncserver-devel"
depends="perl-DBD-mysql perl-Date-Manip perl-LWP  perl-DBI perl-LWP-Protocol-https"
short_desc="Complete video surveillance storage and monitoring solution"
maintainer="Erik Schoepplenberg <erik@puppylinux.com>"
license="GPL-2.0-or-later"
homepage="https://zoneminder.com/"


distfiles="https://github.com/ZoneMinder/zoneminder/archive/refs/tags/"${version}".tar.gz"

# xgensum -i zoneminder
# checksum=""
checksum=59ed8bcaa2376593873b613149ea299b9055443e6d925689b2bf69c56f2deb79

# Allow xbps-src to connect to GitHub during the build phase
allow_net=yes

post_extract() {
    # 1. Initialize an empty Git repository layout over the current files
    git init

    # 2. Tell Git where upstream is so it can map out the submodules
    git remote add origin https://github.com/ZoneMinder/zoneminder

    # 3. Fetch ONLY the specific commit details for this version (no heavy history download)
    git fetch --depth=1 origin "${version}"

    # 4. Force Git to index the existing files matching this tag 
    # instead of doing a destructive checkout
    git reset --mixed FETCH_HEAD

    # 5. Populate and build the missing submodules
    git submodule update --init --recursive
}


post_install() {
    cat > ${DESTDIR}/etc/zm/conf.d/01-system-paths.conf << 'EOF'
ZM_PATH_UNAME=/usr/bin/uname
ZM_PATH_IP=/usr/bin/ip
ZM_PATH_IFCONFIG=/usr/bin/ifconfig
ZM_PATH_SHUTDOWN=/usr/bin/shutdown
ZM_PATH_FFMPEG=/usr/bin/ffmpeg
ZM_PATH_DATA=/var/lib/zoneminder
ZM_PATH_LOGS=/var/log/zoneminder
ZM_PATH_CACHE=/var/cache/zoneminder
ZM_PATH_RUN=/run/zoneminder
ZM_PATH_TEMP=/var/lib/zoneminder/temp
ZM_PATH_EVENTS=/var/lib/zoneminder/events
ZM_PATH_IMAGES=/var/lib/zoneminder/images
ZM_PATH_ZMS=/cgi-bin/nph-zms
EOF
    
echo "Bootstrapping an independent cpanm instance inside the sandbox..."
    
    # Use Perl's native HTTP client instead of external curl
    perl -e '
        use HTTP::Tiny; 
        my $response = HTTP::Tiny->new->get("https://cpanmin.us"); 
        if ($response->{success}) { 
            open(my $fh, ">", "cpanm"); 
            print $fh $response->{content}; 
            close($fh); 
        } else { 
            die "Download failed: $response->{reason}\n"; 
        }
    '
    
    # Ensure the downloaded bootstrap script can be executed
    chmod +x cpanm

    echo "Running standalone cpanm installer layer..."
    
    # Force installation directly inside your targeted package directory
    ./cpanm --notest --no-man-pages -l "${PKGDESTDIR}/usr" \
        Net::WebSocket::Server \
        Net::MQTT::Simple \
        Sys::MemInfo \
        Sys::Mmap \
        Device::SerialPort \
        Number::Bytes::Human \
        LWP::Protocol::https \

    # Clean up the standalone script tool and artifacts
    rm -f cpanm
    rm -rf "${PKGDESTDIR}/usr/lib/perl5/client"
    rm -f "${PKGDESTDIR}/usr/lib/perl5/"*.pod

    # Runit service block
    vmkdir etc/sv/zoneminder
cat << 'EOF' > "${PKGDESTDIR}/etc/sv/zoneminder/run"
#!/bin/sh
exec zmpkg.pl start
EOF
    chmod 0755 "${PKGDESTDIR}/etc/sv/zoneminder/run"
}

