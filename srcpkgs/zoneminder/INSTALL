# This script executes on the host OS during installation
case "$ACTION" in
post)
    echo "Creating and configuring ZoneMinder system directories..."

    # 1. Create required runtime and data directories
    mkdir -p /var/log/zoneminder
    mkdir -p /var/cache/zoneminder/cache
    mkdir -p /var/lib/zoneminder/{events,images,temp}
    mkdir -p /run/zoneminder

    # 2. Detect web server group: prefer 'apache', fallback to 'www-data'
    WEBUSER="www-data"
    WEBGROUP="www-data"
    if getent group apache >/dev/null; then
        WEBGROUP="apache"
    fi

    # 3. Set ownership to web server group for all ZM paths
    chown -R ${WEBUSER}:${WEBGROUP} /var/log/zoneminder
    chown -R ${WEBUSER}:${WEBGROUP} /var/cache/zoneminder
    chown -R ${WEBUSER}:${WEBGROUP} /var/lib/zoneminder    
    chown -R ${WEBUSER}:${WEBGROUP} /var/lib/zoneminder/events
    chown -R ${WEBUSER}:${WEBGROUP} /var/lib/zoneminder/images
    chown -R ${WEBUSER}:${WEBGROUP} /var/lib/zoneminder/temp
    chown -R ${WEBUSER}:${WEBGROUP} /run/zoneminder

    # 4. Set secure permissions:
    # - Directories: 775 (rwxrwxr-x) — group can write
    # - Files:      664 (rw-rw-r--) — group can read/write
    find /var/log/zoneminder /var/cache/zoneminder /var/lib/zoneminder /var/lib/zoneminder/events /var/lib/zoneminder/images /var/lib/zoneminder/temp /run/zoneminder \
        -type d -exec chmod 775 {} \;
    find /var/log/zoneminder /var/cache/zoneminder /var/lib/zoneminder /var/lib/zoneminder/events /var/lib/zoneminder/images /var/lib/zoneminder/temp /run/zoneminder \
        -type f -exec chmod 664 {} \;

    # 5. Enable setgid bit on directories
    # Ensures new files inherit the group of the parent directory
    find /var/log/zoneminder /var/cache/zoneminder /var/lib/zoneminder /var/lib/zoneminder/events /var/lib/zoneminder/images /var/lib/zoneminder/temp /run/zoneminder \
        -type d -exec chmod g+s {} \;

    # 6. Create symlink for web-accessible cache
    # Allows the web interface to access /cache via /usr/share/zoneminder/www/cache
    if [ ! -L /usr/share/zoneminder/www/cache ]; then
        ln -sf /var/cache/zoneminder/cache /usr/share/zoneminder/www/cache
        echo "Symlink created: /usr/share/zoneminder/www/cache → /var/cache/zoneminder/cache"
    fi

    # 7. Check if MariaDB/MySQL is running
    echo "Checking if MySQL/MariaDB is running..."
    if mysqladmin ping --silent >/dev/null 2>&1; then
        echo "Database server is active"

        # Check if 'zm' database already exists
        if mysql -e "USE zm;" >/dev/null 2>&1; then
            echo "Database 'zm' already exists. Skipping initialization."
        else
            echo "Creating database 'zm' and importing schema..."

            # Path to the SQL schema file
            SCHEMA_FILE="/usr/share/zoneminder/db/zm_create.sql"
            if [ -f "$SCHEMA_FILE" ]; then
                # Create database with UTF8MB4 support (for emojis, Cyrillic, etc.)
                mysql -e "CREATE DATABASE zm CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;"

                # Import the default schema
                mysql zm < "$SCHEMA_FILE"

                # Create dedicated database user with privileges
                mysql -e "CREATE USER 'zmuser'@'localhost' IDENTIFIED BY 'zmpass';"
                mysql -e "GRANT ALL PRIVILEGES ON zm.* TO 'zmuser'@'localhost';"
                mysql -e "FLUSH PRIVILEGES;"

                echo "Database initialized: user 'zmuser', password 'zmpass'"
            else
                echo "Error: Schema file not found: $SCHEMA_FILE"
                echo "   Please ensure the package was built correctly."
            fi
        fi
    else
        echo "   MySQL/MariaDB is not running."
        echo "   After starting the service, run manually:"
        echo "   mysql -e 'CREATE DATABASE zm CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;'"
        echo "   mysql zm < /usr/share/zoneminder/db/zm_create.sql"
        echo "   mysql -e \"CREATE USER 'zmuser'@'localhost' IDENTIFIED BY 'zmpass';\""
        echo "   mysql -e \"GRANT ALL PRIVILEGES ON zm.* TO 'zmuser'@'localhost'; FLUSH PRIVILEGES;\""
    fi

    # 8. Create dedicated 'zm' system user for daemons
 #   if ! getent passwd zm >/dev/null; then
 #       adduser -S -D -H -h /var/lib/zoneminder -s /usr/bin/nologin -G ${WEBGROUP} zm
 #       echo "System user 'zm' created (no login, runs daemons)"
 #   fi
    # Ensure zm user owns data directories
 #   chown -R zm:${WEBGROUP} /var/lib/zoneminder 2>/dev/null || true

     chown -R ${WEBUSER}:${WEBGROUP /var/lib/zoneminder 2>/dev/null || true
     chown -R ${WEBUSER}:${WEBGROUP /etc/zm 2>/dev/null || true

    # 9. Enable zoneminder service via runit
    if [ ! -e /var/service/zoneminder ]; then
        ln -sf /etc/sv/zoneminder /var/service/zoneminder
        echo "Service 'zoneminder' enabled (runit)"
    fi

    # 10. Final check: warn about missing Perl modules
    echo "Checking for critical Perl modules..."
    for mod in Sys::Mmap Sys::MemInfo Crypt::Eksblowfish::Bcrypt; do
        if ! perl -e "use $mod" >/dev/null 2>&1; then
            echo "Missing Perl module: $mod"
            echo "   Tip: install it with: cpanm $mod"
        fi
    done

    # Final message
    echo "   ZoneMinder installation complete!"
    echo "   Web interface: http://localhost/zm"
    echo "   Default login: admin / admin (change password after first login)"
    ;;
esac
